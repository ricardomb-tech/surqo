# =============================================================================
# Surqo — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commiteés el .env con valores reales.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM — Proveedor de IA
# Opciones: "groq" (gratis, recomendado) | "anthropic" (pago) | "ollama" (local)
# -----------------------------------------------------------------------------
LLM_PROVIDER=groq
LLM_MAX_TOKENS=1024

# Groq (GRATIS: 14,400 req/día con Llama 3.3 70B)
# Obtener API key gratis en: console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (fallback de pago, opcional)
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-haiku-4-5-20251001

# Ollama (solo para desarrollo local sin internet)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# -----------------------------------------------------------------------------
# Base de datos — Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://<proyecto>.supabase.co
SUPABASE_KEY=<service-role-key>
# JWK público (Settings → API → JWT Settings → JWKS)
SUPABASE_JWK_X=<jwk-x>
SUPABASE_JWK_Y=<jwk-y>
SUPABASE_JWK_KID=<jwk-kid>
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/postgres

# -----------------------------------------------------------------------------
# Frontend — Supabase (variables públicas Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<proyecto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-de-supabase>
# Fly.io URL del backend (reemplaza la de Render)
NEXT_PUBLIC_API_URL=https://surqo-api.fly.dev
NEXT_PUBLIC_WS_URL=wss://surqo-api.fly.dev

# -----------------------------------------------------------------------------
# Cache — Upstash Redis
# -----------------------------------------------------------------------------
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
CACHE_TTL_CLIMATE=3600
CACHE_TTL_ANALYSIS=3600

# -----------------------------------------------------------------------------
# MQTT — HiveMQ Cloud
# -----------------------------------------------------------------------------
HIVEMQ_HOST=<cluster>.s2.eu.hivemq.cloud
HIVEMQ_PORT=8883
HIVEMQ_USERNAME=<usuario-hivemq>
HIVEMQ_PASSWORD=<password-hivemq>
MQTT_TOPIC_PREFIX=surqo

# -----------------------------------------------------------------------------
# Email — Resend
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
FROM_EMAIL=alertas@surqo.io

# -----------------------------------------------------------------------------
# Observabilidad — Logfire (opcional)
# -----------------------------------------------------------------------------
LOGFIRE_TOKEN=<token-de-logfire>

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000","https://surqo.vercel.app"]

# =============================================================================
# GitHub Secrets requeridos para CI/CD (.github/workflows/ci-cd.yml)
# Configúralos en: Settings → Secrets and variables → Actions
# =============================================================================
#
# Secret name               | Descripción
# --------------------------+--------------------------------------------------
# GROQ_API_KEY              | API key de Groq (console.groq.com — gratis)
# ANTHROPIC_API_KEY         | API key de Anthropic (opcional, fallback)
# SUPABASE_URL              | URL de tu proyecto Supabase
# SUPABASE_KEY              | Service Role Key
# SUPABASE_JWK_X            | JWK coordinate X
# SUPABASE_JWK_Y            | JWK coordinate Y
# SUPABASE_JWK_KID          | JWK Key ID
# RESEND_API_KEY            | API key de Resend
# LOGFIRE_TOKEN             | Token de Logfire (opcional)
# FLY_API_TOKEN             | Token de Fly.io (fly.io → Account → Access Tokens)
# VERCEL_TOKEN              | Token de Vercel (Settings → Tokens)
# VERCEL_ORG_ID             | ID de tu organización en Vercel
# VERCEL_PROJECT_ID         | ID del proyecto Surqo en Vercel
# =============================================================================
