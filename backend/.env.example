# ═══════════════════════════════════════════════
# SURQO — Variables de entorno
# "Del surco al insight"
# Copiar a .env y completar los valores
# ═══════════════════════════════════════════════

# ──────────────────────────────────────────────
# LLM PROVIDER
# Opciones: groq | anthropic | ollama
# Groq es el proveedor primario (gratis hasta 14.400 req/día)
# ──────────────────────────────────────────────
LLM_PROVIDER=groq

# Groq (https://console.groq.com → API Keys)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic — fallback opcional (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Ollama — solo desarrollo local sin red
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ──────────────────────────────────────────────
# SUPABASE (https://supabase.com → Settings → API)
# ──────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...   # Service Role Key
DATABASE_URL=postgresql+asyncpg://postgres:TU_PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# JWT ES256 — Supabase Dashboard → Settings → API → JWT Settings → JWKS
SUPABASE_JWK_X=pDWflX5Eq...
SUPABASE_JWK_Y=kaePA94RA...
SUPABASE_JWK_KID=f30d561e-...

# ──────────────────────────────────────────────
# UPSTASH REDIS (https://upstash.com)
# ──────────────────────────────────────────────
REDIS_URL=rediss://default:XXXXXXXXXX@xxxx-xxx-xxxxx.upstash.io:6379
CACHE_TTL_CLIMATE=3600
CACHE_TTL_ANALYSIS=3600

# ──────────────────────────────────────────────
# HIVEMQ CLOUD (https://console.hivemq.cloud)
# ──────────────────────────────────────────────
HIVEMQ_HOST=xxxxxxxxxxxxxxxx.s1.eu.hivemq.cloud
HIVEMQ_PORT=8883
HIVEMQ_USERNAME=surqo-user
HIVEMQ_PASSWORD=tu_password_seguro
MQTT_TOPIC_PREFIX=surqo

# ──────────────────────────────────────────────
# RESEND EMAIL (https://resend.com)
# ──────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=alertas@surqo.io

# ──────────────────────────────────────────────
# APP
# ──────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000","https://surqo.vercel.app"]

# ──────────────────────────────────────────────
# LOGFIRE — observabilidad opcional (https://logfire.pydantic.dev)
# Dejar vacío para deshabilitar
# ──────────────────────────────────────────────
LOGFIRE_TOKEN=
