# ═══════════════════════════════════════════════
# SURQO — Variables de entorno
# "Del surco al insight"
# Copiar a .env y completar los valores
# ═══════════════════════════════════════════════

# ──────────────────────────────────────────────
# ANTHROPIC (https://console.anthropic.com)
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ──────────────────────────────────────────────
# SUPABASE (https://supabase.com → Settings → API)
# ──────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
DATABASE_URL=postgresql+asyncpg://postgres:TU_PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ──────────────────────────────────────────────
# UPSTASH REDIS (https://upstash.com)
# ──────────────────────────────────────────────
REDIS_URL=rediss://default:XXXXXXXXXX@xxxx-xxx-xxxxx.upstash.io:6379

# ──────────────────────────────────────────────
# HIVEMQ CLOUD (https://console.hivemq.cloud)
# ──────────────────────────────────────────────
HIVEMQ_HOST=xxxxxxxxxxxxxxxx.s1.eu.hivemq.cloud
HIVEMQ_PORT=8883
HIVEMQ_USERNAME=surqo-user
HIVEMQ_PASSWORD=tu_password_seguro

# ──────────────────────────────────────────────
# RESEND EMAIL (https://resend.com)
# ──────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=alertas@surqo.io

# ──────────────────────────────────────────────
# APP
# ──────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000","https://surqo.vercel.app"]

# ──────────────────────────────────────────────
# LOGFIRE (https://logfire.pydantic.dev)
# ──────────────────────────────────────────────
LOGFIRE_TOKEN=pylf_xxxxxxxxxxxxxxxxxx
